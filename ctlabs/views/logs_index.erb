<div class="w3-panel w3-green" style="margin-top: 0; margin-bottom: 16px;">
  <h2><i class="fas fa-terminal"></i> Lab Logs</h2>
</div>

<div class="w3-container w3-card-4 w3-padding w3-2021-inkwell" style="border: 1px solid #334155; border-radius: 12px; background-color: #1e293b !important; margin-bottom: 20px;">
  
  <% if @running_lab %>
    <div class="w3-panel w3-round" style="background-color: rgba(56, 189, 248, 0.1); border-left: 4px solid #38bdf8; padding: 12px; margin-top: 0;">
      <strong style="color: #38bdf8;"><i class="fas fa-play-circle"></i> Currently running:</strong> <code><%= @running_lab %></code>
      <% latest_log = LabLog.latest_for_running_lab %>
      <% if latest_log %>
        <% latest_log_id = register_log(latest_log) %>
        <a href="/logs?id=<%= latest_log_id %>"
           class="w3-button w3-small w3-blue w3-round w3-margin-left" style="padding: 4px 10px;">
          <i class="fas fa-eye"></i> View Live Log
        </a>
      <% end %>
    </div>
  <% end %>
  
  <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px; margin-bottom: 15px; border-bottom: 1px solid #334155; padding-bottom: 10px;">
    <h3 style="margin: 0; color: #f8fafc;"><i class="fas fa-history"></i> Recent Logs</h3>
    <% if @log_files.any? %>
      <form method="post" action="/logs/delete-all" style="margin: 0;" onsubmit="return confirm('Delete ALL logs? This cannot be undone.')">
        <button type="submit" class="w3-button w3-red w3-round w3-small">
          <i class="fas fa-trash-alt"></i> Delete All Logs
        </button>
      </form>
    <% end %>
  </div>

  <% if @log_files.empty? %>
    <div class="w3-panel w3-round" style="background-color: #0f172a; border: 1px solid #334155; color: #94a3b8; text-align: center; padding: 30px;">
      <i class="fas fa-folder-open w3-xxlarge w3-margin-bottom" style="opacity: 0.5;"></i>
      <p style="margin: 0;">No logs found.</p>
    </div>
  <% else %>
    <div style="background-color: #0f172a; border: 1px solid #334155; border-radius: 8px; overflow: hidden;">
      <% @log_files.each do |log_path| %>
        <% meta = parse_log_metadata(log_path) %>
        <% log_id = register_log(log_path) %>
        
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; border-bottom: 1px solid #334155; transition: background 0.2s;" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.03)'" onmouseout="this.style.backgroundColor='transparent'">
          <div>
            <strong style="color: #38bdf8; font-size: 1.05em;"><%= meta[:lab_name] %></strong>
            <span style="color: #94a3b8; margin-left: 12px; font-size: 0.9em;">
              <i class="fas fa-tag"></i> <%= meta[:action] %> &nbsp;|&nbsp; 
              <i class="fas fa-clock"></i> <%= meta[:time_str] %>
            </span>
          </div>
          <div style="display: flex; gap: 8px;">
            <a href="/logs?id=<%= log_id %>" class="w3-button w3-small w3-transparent w3-text-blue w3-hover-text-light-coral" title="View Log" style="padding: 4px 10px;">
              <i class="fas fa-eye fa-lg"></i>
            </a>
            <form method="post" action="/logs/delete" style="margin: 0;" onsubmit="return confirm('Delete this log?')">
              <input type="hidden" name="id" value="<%= log_id %>">
              <button type="submit" class="w3-button w3-small w3-transparent w3-text-red w3-hover-text-light-coral" title="Delete Log" style="padding: 4px 10px;">
                <i class="fas fa-trash fa-lg"></i>
              </button>
            </form>
          </div>
        </div>
        
      <% end %>
    </div>
  <% end %>

</div>
