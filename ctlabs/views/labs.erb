<% if latest_log = fetch_latest_log_info %>
  <div id="resume-log" class="w3-panel w3-blue w3-leftbar w3-border-indigo" style="position: sticky; top: 44px; z-index: 990; margin-top: 0; box-shadow: 0 4px 10px -2px rgba(0,0,0,0.4);">
    <p style="margin: 10px 0;">
      <i class="fas fa-play-circle"></i>
      <a href="/logs?id=<%= register_log(latest_log[:path]) %>&lab=<%= ERB::Util.url_encode(latest_log[:lab]) %>&action=<%= ERB::Util.url_encode(latest_log[:action]) %>" style="text-decoration: none; font-weight: bold;">
        Resume latest log
      </a>
      for <code><%= ERB::Util.h(latest_log[:lab]) %></code>
    </p>
  </div>
<% end %>

<div class="w3-panel w3-green">
  <h2><i class="fas fa-flask"></i> Manage Labs</h2>
</div>

<% running = running_lab? %>
<div class="w3-container w3-card-4 w3-padding w3-2021-inkwell">

  <div style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 15px; margin-bottom: 10px;">
    
    <form method="post" action="/labs/execute" style="display: flex; align-items: flex-end; gap: 8px; margin: 0;">
      <div>
        <label style="font-size: 0.85em; color: #94a3b8;"><b>Select Lab:</b></label><br>
        <select name="lab_name" id="lab-selector" class="w3-select w3-medium w3-round select-scroll w3-hover-text-light-green" style="min-width: 200px; padding: 6px;" required <%= 'disabled' if running %>>
          <% @labs.each do |lab| %>
            <option value="<%= lab %>" <%= 'selected' if lab == @selected_lab %>><%= lab %></option>
          <% end %>
        </select>
      </div>
      
      <button type="submit" name="action" value="up" class="w3-button w3-green w3-round" <%= 'disabled' if running %> title="Start Lab">
        <i class="fas fa-play"></i> Start
      </button>
      
      <% if running %>
        <button type="submit" name="action" value="down" class="w3-button w3-red w3-round" title="Stop Lab">
          <i class="fas fa-stop"></i> Stop
        </button>
      <% else %>
        <button type="button" class="w3-button w3-red w3-round w3-opacity" onclick="document.getElementById('not-running-alert').style.display='block'" title="Stop Lab">
          <i class="fas fa-stop"></i> Stop
        </button>
      <% end %>
    </form>

    <div style="display: flex; gap: 8px;">
      <button onclick="window.openVaultLoginModal()" class="w3-button w3-round w3-small" style="background-color: #1e293b; border: 1px solid #334155; margin-right: 8px;">
        <span id="vault-status-indicator">
        <% if session[:vault_token] && !session[:vault_token].empty? %>
          <i class="fas fa-lock w3-text-green"></i> Vault Active
        <% else %>
          <i class="fas fa-unlock w3-text-gray"></i> Vault Login
        <% end %>
        </span>
      </button>

      <button type="button" class="w3-button w3-orange w3-text-white w3-round" onclick="window.openLabYamlEditor()" title="Edit raw Lab YAML">
        <i class="fas fa-file-code"></i> Edit
      </button>

      <button type="button" class="w3-button w3-teal w3-round" onclick="window.openUnifiedSaveModal()" title="Save or Clone Lab">
        <i class="fas fa-save"></i> Save
      </button>
      
      <button type="button" class="w3-button w3-blue w3-round" onclick="document.getElementById('new-lab-modal').style.display='block'">
        <i class="fas fa-folder-plus"></i> New
      </button>
    </div>
  </div> 

  <div id="not-running-alert" class="w3-panel w3-pale-yellow w3-leftbar w3-border-yellow w3-margin-top w3-round" style="display: none; position: relative; padding: 12px;">
    <span onclick="this.parentElement.style.display='none'" class="w3-button w3-display-topright w3-hover-yellow w3-round">&times;</span>
    <strong style="color: #854d0e;"><i class="fas fa-info-circle"></i> No Action Needed:</strong>
    <span style="color: #3f3f46;">There is currently no active lab environment running to stop.</span>
  </div>

  <% if running %>
    <div class="w3-panel w3-orange w3-margin-top w3-round" style="padding:12px;">
      <strong>⚠️ A lab is already running:</strong>
      <code><%= get_running_lab || 'unknown' %></code>
      <br>Please stop it before starting another.

      <div style="margin-top: 10px;">
        <a href="/labs/download?lab=<%= ERB::Util.url_encode(get_running_lab) %>" class="w3-button w3-black w3-round-small">
          <i class="fas fa-download"></i> Download Runtime Config (YAML)
        </a>
      </div>
    </div>
  <% end %>

</div>
<br>

<div id="lab-info-section" class="w3-container w3-2021-inkwell w3-round">
  <% if @lab_info %>
    <%= erb :lab_details, layout: false, locals: { info_hash: @lab_info } %>
  <% else %>
    <div id="lab-info-placeholder" class="w3-panel w3-light-grey">
      <p>Select a lab to view its details.</p>
    </div>
  <% end %>
</div>

<br>

<%= erb :'modals/new_lab' %>
<%= erb :'modals/edit_lab' %>
<%= erb :'modals/vault_login' %>
<%= erb :'modals/file_browser' %>


<div id="unified-save-modal" class="w3-modal" style="z-index: 9999;">
  <div class="w3-modal-content w3-round-large w3-card-4" style="background-color: #1e293b; color: #f8fafc; max-width: 450px;">
    
    <header class="w3-container w3-padding" style="border-bottom: 1px solid #334155; background-color: #0f172a; border-radius: 12px 12px 0 0;">
      <span onclick="document.getElementById('unified-save-modal').style.display='none'" class="w3-button w3-display-topright w3-hover-red w3-round" style="color: #cbd5e1;">&times;</span>
      <h4 style="margin: 0;"><i class="fas fa-save w3-text-teal"></i> Save Lab Configuration</h4>
    </header>
    
    <div class="w3-container w3-padding">
      <div class="w3-panel w3-pale-blue w3-leftbar w3-border-blue w3-small w3-text-black" style="padding: 8px; margin-top: 0;">
        <i class="fas fa-info-circle"></i> <b>Tip:</b> Keep the current name to save your changes, or type a new name to clone this lab!
      </div>
      
      <label style="font-size: 0.85em; color: #94a3b8; font-weight: bold;">Lab Name / Directory:</label>
      <input type="text" id="unified-save-name" class="w3-input w3-small w3-round" style="background-color: #0f172a; color: #e2e8f0; border: 1px solid #475569; margin-top: 4px;" required>
    </div>
    
    <footer class="w3-container w3-padding" style="border-top: 1px solid #334155; background-color: #0f172a; border-radius: 0 0 12px 12px; text-align: right;">
      <button onclick="document.getElementById('unified-save-modal').style.display='none'" class="w3-button w3-round w3-small" style="background-color: #475569;">Cancel</button>
      <button id="unified-save-btn" onclick="window.executeUnifiedSave()" class="w3-button w3-teal w3-round w3-small"><i class="fas fa-check"></i> Save Lab</button>
    </footer>
    
  </div>
</div>

<script>
  window.openUnifiedSaveModal = function() {
    const currentLab = document.getElementById('lab-selector').value;
    if (!currentLab) return alert("No lab selected.");

    const btn = document.getElementById('unified-save-btn');
    btn.innerHTML = '<i class="fas fa-check"></i> Save Lab';
    btn.disabled = false;

    document.getElementById('unified-save-name').value = currentLab;
    document.getElementById('unified-save-modal').style.display = 'block';
  };

  // Notice the new forceOverwrite argument!
  window.executeUnifiedSave = async function(forceOverwrite = false) {
    try {
      const currentLab = document.getElementById('lab-selector').value;
      let targetName = document.getElementById('unified-save-name').value.trim();

      if (!targetName) return alert("Lab name cannot be empty.");

      targetName = targetName.replace(/\.ya?ml$/i, '');
      const normalizedCurrent = currentLab.replace(/\.ya?ml$/i, '');

      const btn = document.getElementById('unified-save-btn');
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
      btn.disabled = true;

      // --- 1. OVERWRITE ITSELF ---
      if (normalizedCurrent === targetName) {
        const safeLab = currentLab.split('/').map(encodeURIComponent).join('/');
        const res = await fetch(`/labs/${safeLab}/save`, { method: 'POST' });
        const data = await res.json();

        if (res.ok) {
          document.getElementById('unified-save-modal').style.display = 'none';
          const infoSection = document.getElementById('lab-info-section');
          if (infoSection) {
             const successDiv = document.createElement('div');
             successDiv.className = 'w3-panel w3-green w3-round w3-margin-bottom';
             successDiv.innerHTML = '<h4><i class="fas fa-check-circle"></i> Saved!</h4><p>Runtime changes permanently saved to base YAML.</p>';
             infoSection.prepend(successDiv);
          }
          setTimeout(() => window.location.reload(), 1500);
        } else {
          throw new Error(data.error || "Unknown backend error during overwrite");
        }
        return;
      }

      // --- 2. CLONE TO NEW LAB (Save As) ---
      const safeLab = currentLab.split('/').map(encodeURIComponent).join('/');
      const formData = new URLSearchParams({ new_lab_name: targetName });
      
      // Inject the force flag if the user confirmed the popup
      if (forceOverwrite) formData.append('force', 'true');

      const res = await fetch(`/labs/${safeLab}/save_as`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: formData.toString()
      });
      
      const data = await res.json();

      if (res.ok) {
        document.getElementById('unified-save-modal').style.display = 'none';
        localStorage.setItem('ctlabs_last_selected_lab', data.new_lab);
        window.location.href = window.location.pathname;
      } else {
        // --- FIX: Catch the EXISTS block and ask the user for permission! ---
        if (data.error === "EXISTS") {
          if (confirm(`WARNING: A lab named '${targetName}' already exists. Do you want to permanently overwrite it?`)) {
             return window.executeUnifiedSave(true); // Re-run with force enabled!
          } else {
             btn.innerHTML = '<i class="fas fa-check"></i> Save Lab';
             btn.disabled = false;
             return;
          }
        }
        throw new Error(data.error || "Unknown backend error during clone");
      }

    } catch (err) {
      alert("Save Failed: " + err.message);
      const btn = document.getElementById('unified-save-btn');
      if (btn) {
        btn.innerHTML = '<i class="fas fa-check"></i> Save Lab';
        btn.disabled = false;
      }
    }
  };
</script>


<div id="lab-yaml-editor-modal" class="w3-modal" style="z-index: 9999; padding-top: 5vh;">
  <div class="w3-modal-content w3-round-large w3-card-4" style="background-color: #1e293b; color: #f8fafc; width: 90%; max-width: 1400px;">
    
    <header class="w3-container w3-padding" style="border-bottom: 1px solid #334155; background-color: #0f172a; border-radius: 12px 12px 0 0;">
      <span onclick="document.getElementById('lab-yaml-editor-modal').style.display='none'" class="w3-button w3-display-topright w3-hover-red w3-round" style="color: #cbd5e1;">&times;</span>
      <h4 style="margin: 0;"><i class="fas fa-file-code w3-text-orange"></i> Edit Lab YAML</h4>
    </header>

    <div class="w3-container w3-padding">
      <textarea id="lab-yaml-editor-textarea" class="w3-input w3-small w3-round" style="display:none;"></textarea>
      <div id="lab-yaml-editor-result" class="w3-panel w3-round w3-small" style="display:none; padding: 8px; margin-top: 10px;"></div>
    </div>

    <footer class="w3-container w3-padding" style="border-top: 1px solid #334155; background-color: #0f172a; border-radius: 0 0 12px 12px; text-align: right;">
      <button onclick="document.getElementById('lab-yaml-editor-modal').style.display='none'" class="w3-button w3-round w3-small" style="background-color: #475569;">Cancel</button>
      <button id="lab-yaml-save-btn" onclick="window.saveLabYaml()" class="w3-button w3-green w3-round w3-small"><i class="fas fa-save"></i> Save YAML</button>
    </footer>
  </div>
</div>

<script>
  window.openLabYamlEditor = async function() {
    const currentLab = document.getElementById('lab-selector').value;
    if (!currentLab) return alert("No lab selected.");

    document.getElementById('lab-yaml-editor-result').style.display = 'none';
    document.getElementById('lab-yaml-editor-modal').style.display = 'block';

    if (!window.cmEditors) window.cmEditors = {};
    if (!window.cmEditors['lab-yaml-editor-textarea']) {
        window.cmEditors['lab-yaml-editor-textarea'] = window.initCodeEditor('lab-yaml-editor-textarea', 'yaml');
        window.cmEditors['lab-yaml-editor-textarea'].setSize(null, "65vh");
    }

    const safeLab = currentLab.split('/').map(encodeURIComponent).join('/');
    try {
        const res = await fetch(`/labs/${safeLab}/raw?t=${Date.now()}`);
        if (!res.ok) throw new Error("Failed to load lab YAML");
        const data = await res.text(); // We just want the raw text
        window.cmEditors['lab-yaml-editor-textarea'].setValue(data);
        setTimeout(() => window.cmEditors['lab-yaml-editor-textarea'].refresh(), 100);
    } catch (err) {
        window.cmEditors['lab-yaml-editor-textarea'].setValue(`# Error loading lab YAML:\n# ${err.message}`);
    }
  };

  window.saveLabYaml = async function() {
    const currentLab = document.getElementById('lab-selector').value;
    const content = window.cmEditors['lab-yaml-editor-textarea'].getValue();
    const btn = document.getElementById('lab-yaml-save-btn');
    const resultDiv = document.getElementById('lab-yaml-editor-result');

    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';

    const safeLab = currentLab.split('/').map(encodeURIComponent).join('/');
    try {
        const res = await fetch(`/labs/${safeLab}/raw`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ yaml_content: content }).toString()
        });
        
        if (!res.ok) throw new Error((await res.json()).error || "Failed to save");

        resultDiv.style.cssText = 'background-color: rgba(16, 185, 129, 0.2); color: #10b981; border: 1px solid #10b981; display: block; margin-top: 10px; padding: 8px;';
        resultDiv.innerHTML = '✅ YAML Saved successfully.';
        setTimeout(() => { window.location.reload(); }, 800);
    } catch (err) {
        resultDiv.style.cssText = 'background-color: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid #ef4444; display: block; margin-top: 10px; padding: 8px;';
        resultDiv.innerHTML = '❌ ' + err.message;
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Save YAML';
    }
  };
</script>
