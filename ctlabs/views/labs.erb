<%= HEADER %>

<%
  # Dynamically find the absolute newest log file using the global LOG_DIR constant
  latest_log_path = Dir.glob(File.join(LOG_DIR, "*.log")).max_by { |f| File.mtime(f) }

  if latest_log_path
    latest_log_file = File.basename(latest_log_path)

    lab_name = "Unknown"
    action_name = "action"

    # Extract lab name and action using regex matching the actual ctlabs format
    # Example format: ctlabs_1773184338_net_net01.yml_up.log
    if match = latest_log_file.match(/^ctlabs_\d+_(.+)_([a-zA-Z]+)\.log$/)
      lab_name = match[1]
      action_name = match[2]
    end
%>
  <div id="resume-log" class="w3-panel w3-blue w3-leftbar w3-border-indigo" style="position: sticky; top: 44px; z-index: 990; margin-top: 0; box-shadow: 0 4px 10px -2px rgba(0,0,0,0.4);">
    <p style="margin: 10px 0;">
      <i class="fas fa-play-circle"></i>
      <a href="/logs?file=<%= ERB::Util.url_encode(latest_log_path) %>&lab=<%= ERB::Util.url_encode(lab_name) %>&action=<%= ERB::Util.url_encode(action_name) %>" style="text-decoration: none; font-weight: bold;">
        Resume latest log
      </a>
      for <code><%= ERB::Util.h(lab_name) %></code>
    </p>
  </div>
<% end %>

<div class="w3-panel w3-green">
  <h2><i class="fas fa-flask"></i> Manage Labs</h2>
</div>

<% running = running_lab? %>
<div class="w3-container w3-card-4 w3-padding w3-2021-inkwell">
  <form method="post" action="/labs/execute">
    <label><b>Select Lab:</b></label>
    <select name="lab_name" id="lab-selector" class="w3-select w3-margin-bottom" required <%= 'disabled' if running %>>
      <% @labs.each do |lab| %>
        <option value="<%= lab %>" <%= 'selected' if lab == @selected_lab %>><%= lab %></option>
      <% end %>
    </select>
    <br/>
    <button type="submit" name="action" value="up" class="w3-button w3-green w3-round" <%= 'disabled' if running %>> ▶ Start Lab </button>
    
    <% if running %>
      <button type="submit" name="action" value="down" class="w3-button w3-red w3-round"> ⏹ Stop Lab </button>
    <% else %>
      <button type="button" class="w3-button w3-red w3-round w3-opacity" onclick="document.getElementById('not-running-alert').style.display='block'"> ⏹ Stop Lab </button>
    <% end %>
  </form>

  <div id="not-running-alert" class="w3-panel w3-pale-yellow w3-leftbar w3-border-yellow w3-margin-top w3-round" style="display: none; position: relative; padding: 12px;">
    <span onclick="this.parentElement.style.display='none'" class="w3-button w3-display-topright w3-hover-yellow w3-round">&times;</span>
    <strong style="color: #854d0e;"><i class="fas fa-info-circle"></i> No Action Needed:</strong> 
    <span style="color: #3f3f46;">There is currently no active lab environment running to stop.</span>
  </div>

  <% if running %>
    <div class="w3-panel w3-orange w3-margin-top w3-round" style="padding:12px;">
      <strong>⚠️ A lab is already running:</strong>
      <code><%= get_running_lab || 'unknown' %></code>
      <br>Please stop it before starting another.
      
      <div style="margin-top: 10px;">
        <a href="/labs/download?lab=<%= ERB::Util.url_encode(get_running_lab) %>" class="w3-button w3-black w3-round-small">
          <i class="fas fa-download"></i> Download Runtime Config (YAML)
        </a>
      </div>
    </div>
  <% end %>
</div>

<br>

<!-- Lab Info Card Section -->
<div id="lab-info-section" class="w3-container w3-2021-inkwell w3-round">
  <% if @lab_info %>
    <%= render_lab_info_card(@lab_info) %> <!-- Use the helper -->
  <% else %>
    <div id="lab-info-placeholder" class="w3-panel w3-light-grey">
      <p>Select a lab to view its details.</p>
    </div>
  <% end %>
</div>

<br>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const selectElement = document.getElementById('lab-selector');
    const infoSection = document.getElementById('lab-info-section');
    let refreshTimer = null; // Holds our background heartbeat

    // Function to fetch and update the card
    const fetchLabInfo = (selectedLab, isAutoRefresh = false) => {
      
      // SAFETY CHECK: Do not auto-refresh if the user is typing in a modal!
      if (isAutoRefresh) {
        const modals = ['add-node-modal', 'node-editor-modal', 'ansible-editor-modal'];
        const isEditing = modals.some(id => {
          const el = document.getElementById(id);
          return el && el.style.display === 'block';
        });
        if (isEditing) return; // Skip this refresh tick so we don't interrupt them
      } else {
        // Only show the big loading spinner on a manual/initial load
        infoSection.innerHTML = '<div class="w3-panel w3-flat-midnight-blue w3-round"><p><i class="fas fa-spinner fa-spin"></i> Loading lab info...</p></div>';
      }

      fetch(`/labs/${encodeURIComponent(selectedLab)}/info_card`)
        .then(response => {
            if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
            return response.text(); 
        })
        .then(htmlFragment => {
            infoSection.innerHTML = htmlFragment;
        })
        .catch(error => {
            console.error('Error fetching lab info card:', error);
            if (!isAutoRefresh) {
              infoSection.innerHTML = '<div class="w3-panel w3-red w3-round"><h4><i class="fas fa-exclamation-triangle"></i> Error</h4><p>Could not load lab info.</p></div>';
            }
        });
    };

    if (selectElement) {
      // 1. Recover the last selected lab from local storage
      const savedLab = localStorage.getItem('ctlabs_last_selected_lab');
      
      if (savedLab && !selectElement.disabled) {
        const exists = Array.from(selectElement.options).some(opt => opt.value === savedLab);
        if (exists) selectElement.value = savedLab;
      }

      // 2. Setup the Dropdown Change Event
      selectElement.addEventListener('change', function() {
        const selectedLab = this.value;
        if (selectedLab) {
          localStorage.setItem('ctlabs_last_selected_lab', selectedLab);
          
          // Clear any existing timer when switching labs
          if (refreshTimer) clearInterval(refreshTimer);
          
          // A) Fetch immediately with the loading spinner
          fetchLabInfo(selectedLab, false);
          
          // B) Start the silent auto-refresh loop (Every 5 seconds)
          refreshTimer = setInterval(() => {
            fetchLabInfo(selectedLab, true);
          }, 5000);
        }
      });

      // 3. Fire the change event immediately on page load
      if (selectElement.value) {
        selectElement.dispatchEvent(new Event('change'));
      }
    }
  });
</script>
<%= FOOTER %>
