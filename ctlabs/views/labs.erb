<style>
  /* Custom Slim Dark Scrollbar specifically for the Container Images Table */
  .select-scroll::-webkit-scrollbar { width: 4px; height: 4px; }
  .select-scroll::-webkit-scrollbar-track { background: #0f172a; border-radius: 4px; }
  .select-scroll::-webkit-scrollbar-thumb { background: #475569; border-radius: 4px; }
  .select-scroll::-webkit-scrollbar-thumb:hover { background: #64748b; }
  select.w3-select  { font-family: monospace !important; }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/dockerfile.min.js"></script>
<script src="/js/terminal.js"></script>
<script src="/js/labs.js"></script>
<script src="/js/links.js"></script>
<script src="/js/code_editor.js"></script>
<script src="/js/file_browser.js"></script>
<script src="/js/dockerfile.js"></script>
<script src="/js/automation.js"></script>
<script src="/js/nodes.js"></script>
<script src="/js/profiles.js"></script>
<script src="/js/images.js"></script>
