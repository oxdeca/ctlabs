              if (data.json.nics) {
                  for (const [key, value] of Object.entries(data.json.nics)) {
                      nicsStr += `${key}=${value}\n`;
                  }
              }
              document.getElementById('edit-nics').value = nicsStr.trim();

              let urlStr = '';
              if (data.json.urls && typeof data.json.urls === 'object') {
