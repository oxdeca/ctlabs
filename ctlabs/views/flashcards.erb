<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<link rel="stylesheet" href="/css/flashcards.css">
<script src="/js/flashcards.js"></script>

<div class="w3-panel w3-green" style="margin-top: 0; margin-bottom: 16px;">
  <h2><i class="fas fa-layer-group"></i> Flashcards</h2>
</div>

<div id="flashcards-container" data-theme="dark" data-read-only="<%= @read_only %>">
  <div id="card-app">
    <div class="progress-container">
      <div id="progress-bar"></div>
    </div>
    <div class="card-toolbar">
      <div class="toolbar-group">
        <button id="btn-newset" class="w3-button admin-tool" onclick="app.newSet()" title="New Set">
          <i class="fa fa-folder-plus btn-blue"></i>
        </button>
        <button id="btn-import" class="w3-button admin-tool" onclick="app.triggerFileImport()" title="Import JSON">
          <i class="fa fa-file-upload btn-green"></i>
        </button>
        <button class="w3-button admin-tool" onclick="app.exportSet()" title="Export">
          <i class="fa fa-file-download btn-purple"></i>
        </button>
        <button class="w3-button admin-tool" onclick="app.clearCache()" title="Clear Data">
          <i class="fa fa-eraser btn-red"></i>
        </button>
      </div>
      
      <div class="toolbar-group">
        <div id="counter" class="text-accent" style="font-weight:600;">0 / 0</div>
        <div id="quiz-timer" class="text-accent" style="display:none; margin-left:10px;">
          <i class="fa fa-clock"></i> <span id="timer-display">00:00</span>
        </div>
      </div>
      
      <div class="toolbar-group">
        <button class="w3-button" onclick="app.showSetInfo()" title="Cardset Info">
          <i class="fa fa-info-circle btn-blue"></i>
        </button>
        <button class="w3-button" id="btn-stats" onclick="app.showLiveStats()" style="display:none;" title="Live Stats">
          <i class="fa fa-chart-bar btn-green"></i>
        </button>
        <button class="w3-button" id="btn-quiz" onclick="app.toggleQuiz()" title="Quiz Mode">
          <i class="fa fa-graduation-cap"></i>
        </button>
        <button class="w3-button admin-tool" onclick="app.deleteCard()" title="Delete">
          <i class="fa fa-trash btn-red"></i>
        </button>
        <button id="btn-add" class="w3-button admin-tool" onclick="app.addCard()" title="Add">
          <i class="fa fa-plus-circle btn-blue"></i>
        </button>
        <button id="btn-raw" class="w3-button admin-tool" onclick="app.openRawImport()" title="Import Paste">
          <i class="fa fa-paste btn-blue"></i>
        </button>
        <button class="w3-button admin-tool" onclick="app.toggleEditMode()" title="Edit">
          <i class="fa fa-edit btn-orange"></i>
        </button>
      </div>
    </div>
    <div id="ccard">
      <div id="display-area">
        <header id="qheader" class="w3-container"></header>
        <div id="panswers" class="w3-container"></div>
        <div id="cinfo" class="w3-container" style="display:none"></div>
      </div>
      <footer id="qfooter">
        <button id="btn-prev" class="w3-button" onclick="app.prev()">
          <i class="fa fa-chevron-left btn-blue"></i>
        </button>
        <button id="btn-main" class="w3-button w3-blue" style="flex:2" onclick="app.handleAction()">Check</button>
        <button id="btn-next" class="w3-button" onclick="app.next()">
          <i class="fa fa-chevron-right btn-blue"></i>
        </button>
      </footer>
    </div>
  </div>
  <div id="modal-container" class="modal-overlay" onclick="app.closeModal()">
    <div class="modal-card" onclick="event.stopPropagation()">
      <div class="modal-header">
        <div id="modal-title" class="modal-title"></div>
        <i class="fa fa-times modal-close-x" onclick="app.closeModal()"></i>
      </div>
      <div id="modal-body" class="modal-body"></div>
      <div id="modal-footer" class="modal-footer" style="display:none"></div>
    </div>
  </div>
  <input type="file" id="file-input" style="display:none">
  <br>
</div>
