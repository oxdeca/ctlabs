<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Terminal: <%= @node_name %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body, html {
      margin:      0; padding: 0; height: 100%;
      background:  #0f172a; color: #f8fafc;
      font-family: sans-serif; overflow: hidden;
      display:     flex; flex-direction: column;
    }
    #header {
      background:    #1e293b; 
      padding:       4px 12px;
      border-bottom: 1px solid #334155;
      display:       flex; justify-content: space-between; align-items: center;
      flex-shrink:   0; font-size: 0.85em;
    }
    .status { color: #10b981; font-size: 0.85em; }
    .status.disconnected { color: #ef4444; }
    
    /* --- UNIFIED SLIM SCROLLBARS --- */
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: #0f172a; }
    ::-webkit-scrollbar-thumb { background: #334155; border-radius: 4px; border: 2px solid #0f172a; }
    ::-webkit-scrollbar-thumb:hover { background: #475569; }
    
    .xterm-viewport { scrollbar-width: thin; scrollbar-color: #334155 #0f172a; }
    
    #terminal-container {
      width: 100%; flex: 1 1 0; height: 0; min-height: 0;
      padding: 2px; box-sizing: border-box; overflow: hidden;
    }
    .xterm { height: 100%; }
  </style>
</head>
<body data-node-name="<%= ERB::Util.html_escape(@node_name) %>">
  
  <div id="header">
    <strong><i class="fas fa-terminal"></i> <%= @node_name %></strong>
    <span id="status" class="status"><i class="fas fa-circle"></i> Connecting...</span>
  </div>
  <div id="terminal-container"></div>

  <script src="https://cdn.jsdelivr.net/npm/xterm@5.3.0/lib/xterm.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xterm-addon-fit@0.8.0/lib/xterm-addon-fit.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const container = document.getElementById('terminal-container');
      const nodeName = document.body.dataset.nodeName;

      const term = new Terminal({
        theme: { background: '#300a24', foreground: '#ffffff', cursor: '#ffffff', selectionBackground: 'rgba(56, 189, 248, 0.3)' },
        fontFamily: '"Courier New", Courier, monospace',
        cursorBlink: true, fontSize: 14
      });

      term.onSelectionChange(() => {
          const selection = term.getSelection();
          if (selection) navigator.clipboard.writeText(selection);
      });

      const fitAddon = new FitAddon.FitAddon();
      term.loadAddon(fitAddon);
      term.open(container);
      
      const protocol = window.location.protocol === 'https:' ? 'wss://' : 'ws://';
      const wsUrl = protocol + window.location.host + '/terminal/' + encodeURIComponent(nodeName);
      const ws = new WebSocket(wsUrl);
      const statusEl = document.getElementById('status');

      setTimeout(() => {
        fitAddon.fit();
        if (ws.readyState === WebSocket.OPEN) {
          ws.send(JSON.stringify({ type: 'resize', cols: term.cols, rows: term.rows }));
        }
      }, 100);

      ws.onopen = () => {
        statusEl.innerHTML = '<i class="fas fa-circle"></i> Connected';
        term.focus();
      };

      ws.onmessage = (event) => term.write(event.data);

      ws.onclose = () => {
        statusEl.innerHTML = '<i class="fas fa-times-circle"></i> Disconnected';
        statusEl.classList.add('disconnected');
        term.write('\r\n\x1b[31m[Connection closed]\x1b[0m\r\n');
      };

      term.onData(data => {
        if (ws.readyState === WebSocket.OPEN) ws.send(JSON.stringify({ type: 'input', data: data }));
      });

      term.onResize(size => {
        if (ws.readyState === WebSocket.OPEN) ws.send(JSON.stringify({ type: 'resize', cols: size.cols, rows: size.rows }));
      });

      window.addEventListener('resize', () => fitAddon.fit());
    });
  </script>
</body>
</html>
