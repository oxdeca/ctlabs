<%
  # Cache the local registry images so we only run the shell commands once!
  unless @local_built_images
    @local_built_images = `podman images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null`.split("\n").map(&:strip)
    @local_built_images += `docker images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null`.split("\n").map(&:strip)
    @local_built_images.map! do |img|
      img.sub(%r{^localhost/}, '').sub(%r{^docker\.io/library/}, '').sub(%r{^docker\.io/}, '').sub(%r{^quay\.io/}, '')
    end
    @local_built_images.uniq!
    @local_built_images.reject! { |img| img == "<none>:<none>" || img.empty? }
  end
  
  # Filter to strictly show ctlabs images for the dropdown
  ctlabs_images = @local_built_images.select { |img| img.start_with?("ctlabs/") }.sort
%>

<div id="image-editor-modal" class="w3-modal" style="z-index: 9999;">
  <div class="w3-modal-content w3-round-large w3-card-4" style="background-color: #1e293b; color: #f8fafc; max-width: 450px;">
    <header class="w3-container w3-padding" style="border-bottom: 1px solid #334155; background-color: #0f172a; border-radius: 12px 12px 0 0;">
      <span onclick="document.getElementById('image-editor-modal').style.display='none'" class="w3-button w3-display-topright w3-hover-red w3-round" style="color: #cbd5e1;">&times;</span>
      <h4 style="margin: 0;"><i class="fas fa-box-open"></i> Add/Edit Profile</h4>
    </header>
    
    <div class="w3-container w3-padding">
      <div class="w3-margin-bottom">
        <label style="font-size: 0.85em; color: #94a3b8;">Node Type & Kind</label>
        <div class="w3-row-padding" style="margin: 0 -8px;">
          <div class="w3-col s6" style="padding: 0 8px;">
            <select id="edit-img-type" class="w3-input w3-small w3-round" style="background-color: #0f172a; color: #e2e8f0; border: 1px solid #475569; height: 32px;">
              <option value="" disabled selected>Select Type...</option>
              <option value="router">router</option>
              <option value="switch">switch</option>
              <option value="firewall">firewall</option>
              <option value="host">host</option>
              <option value="server">server</option>
              <option value="controller">controller</option>
              <option value="gateway">gateway</option>
            </select>
          </div>
          <div class="w3-col s6" style="padding: 0 8px;">
            <input type="text" id="edit-img-kind" class="w3-input w3-small w3-round" placeholder="e.g. linux" style="background-color: #0f172a; color: #e2e8f0; border: 1px solid #475569; height: 32px;">
          </div>
        </div>
      </div>

      <div class="w3-margin-bottom">
        <label style="font-size: 0.85em; color: #94a3b8;">Image Reference (ctlabs/*)</label>
        <input type="text" id="edit-img-ref" list="edit-img-ref-list" class="w3-input w3-small w3-round" placeholder="Double-click to browse or type image..." style="background-color: #0f172a; color: #e2e8f0; border: 1px solid #475569; height: 32px;">
        <datalist id="edit-img-ref-list">
          <% ctlabs_images.each do |img| %>
            <option value="<%= img %>"><%= img %></option>
          <% end %>
        </datalist>
      </div>

      <div class="w3-margin-bottom">
        <label style="font-size: 0.85em; color: #94a3b8;">Capabilities (caps) - Comma separated</label>
        <input type="text" id="edit-img-caps" class="w3-input w3-small w3-round" placeholder="SYS_PTRACE, IPC_LOCK" style="background-color: #0f172a; color: #e2e8f0; border: 1px solid #475569;">
      </div>

      <div class="w3-margin-bottom">
        <label style="font-size: 0.85em; color: #94a3b8;">Environment Variables (env) - One per line</label>
        <textarea id="edit-img-env" class="w3-input w3-small w3-round slim-scroll" rows="2" placeholder="VAR=value" style="background-color: #0f172a; color: #e2e8f0; border: 1px solid #475569; font-family: monospace; resize: vertical;"></textarea>
      </div>

      <div class="w3-margin-bottom">
        <label style="font-size: 0.85em; color: #94a3b8;">Extra Attributes (YAML formatting)</label>
        <textarea id="edit-img-extras" class="w3-input w3-small w3-round slim-scroll" rows="3" placeholder="ports: 18&#10;privileged: true" style="background-color: #0f172a; color: #e2e8f0; border: 1px solid #475569; font-family: monospace; resize: vertical;"></textarea>
      </div>

      <div id="image-editor-result" class="w3-panel w3-round" style="display:none; font-size: 0.9em; padding: 8px;"></div>
    </div>

    <footer class="w3-container w3-padding" style="border-top: 1px solid #334155; background-color: #0f172a; border-radius: 0 0 12px 12px; text-align: right;">
      <button type="button" onclick="document.getElementById('image-editor-modal').style.display='none'" class="w3-button w3-round w3-small" style="background-color: #475569;">Cancel</button>
      <button type="button" onclick="window.saveImageConfig()" class="w3-button w3-green w3-round w3-small"><i class="fas fa-save"></i> Save</button>
    </footer>
  </div>
</div>
