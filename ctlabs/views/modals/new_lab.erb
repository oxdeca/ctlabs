<link rel="stylesheet" href="/css/modal.css">

<div id="new-lab-modal" class="w3-modal" style="z-index: 9999;">
    <div class="w3-modal-content w3-round-large w3-card-4" style="background-color: #1e293b; color: #f8fafc; max-width: 400px;">
      <header class="w3-container w3-padding" style="border-bottom: 1px solid #334155; background-color: #0f172a; border-radius: 12px 12px 0 0;">
        <span onclick="document.getElementById('new-lab-modal').style.display='none'" class="w3-button w3-display-topright w3-hover-red w3-round" style="color: #cbd5e1;">&times;</span>
        <h4 style="margin: 0;"><i class="fas fa-folder-plus"></i> Create New Lab</h4>
      </header>
      <form method="post" action="/labs/new">
        <div class="w3-container w3-padding">
          <label style="font-size: 0.85em; color: #94a3b8;">Lab Filename (e.g. custom/my_lab.yml)</label>
          <input type="text" name="lab_name" class="w3-input w3-small w3-round w3-margin-bottom" required style="background-color: #0f172a; color: #e2e8f0; border: 1px solid #475569;">

          <label style="font-size: 0.85em; color: #94a3b8;">Description</label>
          <input type="text" name="desc" class="w3-input w3-small w3-round" style="background-color: #0f172a; color: #e2e8f0; border: 1px solid #475569;">
        </div>
        <footer class="w3-container w3-padding" style="border-top: 1px solid #334155; background-color: #0f172a; border-radius: 0 0 12px 12px; text-align: right;">
          <button type="button" onclick="document.getElementById('new-lab-modal').style.display='none'" class="w3-button w3-round w3-small" style="background-color: #475569;">Cancel</button>
          <button type="submit" class="w3-button w3-green w3-round w3-small"><i class="fas fa-save"></i> Create</button>
        </footer>
      </form>
    </div>
  </div>