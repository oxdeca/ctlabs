<div id="add-container-image" class="w3-modal" style="z-index: 9999;">
    <div class="w3-modal-content w3-round-large w3-card-4" style="background-color: #1e293b; color: #f8fafc; max-width: 450px;">
      <header class="w3-container w3-padding" style="border-bottom: 1px solid #334155; background-color: #0f172a; border-radius: 12px 12px 0 0;">
        <span onclick="document.getElementById('add-container-image').style.display='none'" class="w3-button w3-display-topright w3-hover-red w3-round" style="color: #cbd5e1;">&times;</span>
        <h4 style="margin: 0;"><i class="fas fa-box w3-text-orange"></i> Add / Import Image</h4>
      </header>
      <form onsubmit="window.submitNewLocalImage(event)">
        <div class="w3-container w3-padding">
          <label style="font-size: 0.9em; color: #38bdf8; font-weight: bold;"><i class="fas fa-folder-plus"></i> Create Local Dockerfile</label>
          <p style="font-size: 0.8em; color: #94a3b8; margin: 4px 0 8px 0;">Creates a new blank folder structure in ../images/</p>
          <div style="display: flex; gap: 8px;">
            <input type="text" name="image_path" class="w3-input w3-small w3-round" placeholder="e.g. category/os/kind" required style="flex: 1; background-color: #0f172a; color: #e2e8f0; border: 1px solid #475569;">
            <button type="submit" class="w3-button w3-blue w3-round w3-small" style="white-space: nowrap;">Create</button>
          </div>
        </div>
      </form>
      <hr style="border-color: #334155; margin: 0;">
      <form onsubmit="window.submitPullImage(event)">
        <div class="w3-container w3-padding w3-margin-bottom">
          <label style="font-size: 0.9em; color: #a855f7; font-weight: bold;"><i class="fas fa-cloud-download-alt"></i> Pull External Image</label>
          <p style="font-size: 0.8em; color: #94a3b8; margin: 4px 0 8px 0;">Downloads an image directly into the registry</p>
          <div style="display: flex; gap: 8px;">
            <input type="text" name="image_name" class="w3-input w3-small w3-round" placeholder="e.g. nginx:latest or alpine" required style="flex: 1; background-color: #0f172a; color: #e2e8f0; border: 1px solid #475569;">
            <button type="submit" class="w3-button w3-deep-purple w3-round w3-small" style="white-space: nowrap;">Pull Image</button>
          </div>
        </div>
      </form>
    </div>
  </div>