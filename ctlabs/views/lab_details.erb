<% if info_hash.nil? || info_hash[:error] %>
  <div class="w3-panel w3-red w3-round-large">
    <h4><i class="fas fa-exclamation-triangle"></i> Error Loading Lab Info</h4>
    <p><%= info_hash ? info_hash[:error] : "Lab data not found." %></p>
  </div>
<% else %>
  <div class="w3-panel w3-round-large" style="background-color: #1e293b; padding: 20px;">
    
    <% is_running = defined?(get_running_lab) ? (get_running_lab == info_hash[:lab_path]) : false %>
    <% safe_images_map = (info_hash[:images_map] || {}).to_json %>
    <% routers_list = (info_hash[:nodes] || []).select { |n| n[:type] == 'router' }.map { |n| n[:name] }.to_json %>
    <% switches_list = (info_hash[:switches] || []).to_json %>
    <% switch_gw_map = generate_switch_gw_map(info_hash[:lab_path], info_hash[:links]) %>

    <div id="lab-running-state" data-is-running="<%= is_running %>" style="display:none;"></div>
    <div id="lab-dynamic-data" 
         data-images-map="<%= Rack::Utils.escape_html(safe_images_map) %>" 
         data-routers="<%= Rack::Utils.escape_html(routers_list) %>"
         data-switches="<%= Rack::Utils.escape_html(switches_list) %>"
         data-switch-gws="<%= Rack::Utils.escape_html(switch_gw_map.to_json) %>"
         style="display:none;">
    </div>

    <div style="border-bottom: 1px solid #334155; padding-bottom: 15px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: flex-start;">
      <div>
        <h3 style="margin:0; font-weight: 600; color: #38bdf8;"><i class="fas fa-flask"></i> <%= info_hash[:lab_name] || "Unknown Lab" %></h3>
        <span style="color: #94a3b8; font-size: 0.95em;"><%= info_hash[:desc] || "No description provided." %></span>
      </div>
      <button class="w3-button w3-small w3-round w3-blue" onclick="window.openEditLabModal('<%= info_hash[:lab_path] %>')" title="Edit Lab Properties" style="padding: 4px 8px; margin-top: 4px;">
        <i class="fas fa-edit"></i> Edit
      </button>
    </div>

    <div id="lab-layout-wrapper" style="display: flex; align-items: stretch; min-height: 500px; border: 1px solid #334155; border-radius: 12px; background-color: #1e293b;">
      
      <div style="flex: 0 0 220px; background-color: #0f172a; border-right: 1px solid #334155; border-radius: 12px 0 0 12px; padding: 16px;">
        <h5 style="color: #94a3b8; font-size: 0.85em; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px; margin-top: 0;">Lab Details</h5>
        
        <div class="w3-bar-block">
          <button class="w3-bar-item w3-button lab-tab-btn w3-round w3-margin-bottom" style="text-align: left; background-color: #38bdf8; color: #0f172a; font-weight: bold;" onclick="openLabTab(event, 'tab-overview')">
            <i class="fas fa-info-circle" style="width: 20px;"></i> Overview
          </button>
          <button class="w3-bar-item w3-button lab-tab-btn w3-round w3-margin-bottom" style="text-align: left; background-color: #cbd5e1;" onclick="openLabTab(event, 'tab-automation')">
            <i class="fas fa-robot"></i> Automation
          </button>
          <button class="w3-bar-item w3-button lab-tab-btn w3-round w3-margin-bottom w3-hover-deep-purple" style="text-align: left; color: #cbd5e1;" onclick="openLabTab(event, 'tab-nodes')">
            <i class="fas fa-server" style="width: 20px;"></i> Nodes
          </button>
          <button class="w3-bar-item w3-button lab-tab-btn w3-round w3-margin-bottom w3-hover-teal" style="text-align: left; color: #cbd5e1;" onclick="openLabTab(event, 'tab-links')">
            <i class="fas fa-network-wired" style="width: 20px;"></i> Links
          </button>
          <button class="w3-bar-item w3-button lab-tab-btn w3-round w3-margin-bottom w3-hover-orange" style="text-align: left; color: #cbd5e1;" onclick="openLabTab(event, 'tab-images')">
            <i class="fas fa-layer-group" style="width: 20px;"></i> Image Profiles
          </button>
          <button class="w3-bar-item w3-button lab-tab-btn w3-round w3-margin-bottom w3-hover-pink" style="text-align: left; color: #cbd5e1;" onclick="openLabTab(event, 'tab-container-images')">
            <i class="fas fa-box" style="width: 20px;"></i> Container Images
          </button>
        </div>
      </div>

      <div style="flex: 1; padding: 20px; overflow-y: hidden; display: flex; flex-direction: column; min-height: 0;">
        
        <div id="tab-overview" class="lab-tab-content" style="flex: 1; min-height: 0; flex-direction: column; overflow-y: auto;">
          <%= erb :'cards/overview', locals: { info_hash: info_hash } %>
        </div>

         <div id="tab-automation" class="lab-tab-content" style="display: none; flex: 1; min-height: 0; flex-direction: column; overflow-y: hidden;">
          <%= erb :'cards/automation', locals: { info_hash: info_hash } %>
        </div>
        
        <div id="tab-nodes" class="lab-tab-content" style="display: none; flex: 1; min-height: 0; flex-direction: column; overflow-y: hidden;">
          <%= erb :'cards/nodes', locals: { info_hash: info_hash } %>
        </div>
        
        <div id="tab-links" class="lab-tab-content" style="display: none; flex: 1; min-height: 0; flex-direction: column; overflow-y: auto;">
          <%= erb :'cards/links', locals: { info_hash: info_hash } %>
        </div>
        
        <div id="tab-images" class="lab-tab-content" style="display: none; flex: 1; min-height: 0; flex-direction: column; overflow-y: auto;">
          <%= erb :'cards/images', locals: { info_hash: info_hash } %>
        </div>
        
        <div id="tab-container-images" class="lab-tab-content" style="display: none; flex: 1; min-height: 0; flex-direction: column; overflow-y: hidden;">
          <%= erb :'cards/container_images', locals: { info_hash: info_hash } %>
        </div>
        
      </div>
    </div>
  </div>

  <%= erb :'modals/add_node', locals: { info_hash: info_hash } %>
  <%= erb :'modals/edit_node' %>
  <%= erb :'modals/add_image' %>
  <%= erb :'modals/edit_image' %>
  <%= erb :'modals/build_image' %>
  <%= erb :'modals/ansible_editor' %>
  <%= erb :'modals/terraform_editor' %>
  <%= erb :'modals/link_editor' %>

<% end %>
