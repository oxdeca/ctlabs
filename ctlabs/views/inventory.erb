<script src="/js/inventory.js"></script>
<script src="/js/labs.js"></script>

<% inv_contents = fetch_inventory_contents %>

    <div id="inv-header" class="w3-panel w3-green" style="margin-top: 0; margin-bottom: 16px;">
      <h2><i class="fas fa-list-alt"></i> Ansible Inventories</h2>
    </div>

    <div class="w3-bar w3-round-large w3-margin-bottom" style="background-color: #1e293b; border: 1px solid #334155;">
      <button class="w3-bar-item w3-button tablink w3-blue w3-round-large" onclick="openInvTab(event, 'MgmtInv')" style="font-weight: 600;">
        <i class="fas fa-network-wired"></i> Management Network
      </button>
      <button class="w3-bar-item w3-button tablink w3-round-large" onclick="openInvTab(event, 'DataInv')" style="font-weight: 600;">
        <i class="fas fa-project-diagram"></i> Data Network
      </button>
    </div>

    <div id="MgmtInv" class="w3-container inv-tab w3-margin-bottom" style="padding: 0;">
      <div class="w3-panel w3-round-large" style="background-color: rgba(59, 130, 246, 0.1); border: 1px solid #3b82f6; margin-top: 0;">
        <h4 style="color: #38bdf8; margin-top: 10px;"><i class="fas fa-info-circle"></i> Management Network (eth0)</h4>
        <p style="color: #e2e8f0; font-size: 0.9em;">This inventory connects to the infrastructure over the isolated management plane.</p>
      </div>
      <div class="w3-card-4 w3-round-large" style="border: 1px solid #475569; overflow: hidden; background-color: #0f172a;">
        <textarea id="mgmt-inv-viewer"><%= ERB::Util.h(inv_contents[:mgmt]) %></textarea>
      </div>
    </div>

    <div id="DataInv" class="w3-container inv-tab w3-margin-bottom" style="display:none; padding: 0;">
      <div class="w3-panel w3-round-large" style="background-color: rgba(16, 185, 129, 0.1); border: 1px solid #10b981; margin-top: 0;">
        <h4 style="color: #10b981; margin-top: 10px;"><i class="fas fa-info-circle"></i> Data Network (eth1 / ipv4)</h4>
        <p style="color: #e2e8f0; font-size: 0.9em;">This inventory allows targeted configuration of data-plane services directly over the simulated network.</p>
      </div>
      <div class="w3-card-4 w3-round-large" style="border: 1px solid #475569; overflow: hidden; background-color: #0f172a;">
        <textarea id="data-inv-viewer"><%= ERB::Util.h(inv_contents[:data]) %></textarea>
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
          if (typeof window.initCodeEditor === 'function') {
              // 1. Initialize Management Inventory Editor
              const mgmtViewer = window.initCodeEditor('mgmt-inv-viewer', 'properties');
              if (mgmtViewer) {
                  mgmtViewer.setOption('readOnly', true);
                  mgmtViewer.getWrapperElement().style.minHeight = "auto";
                  mgmtViewer.getWrapperElement().style.height = "auto";
              }

              // 2. Initialize Data Inventory Editor
              const dataViewer = window.initCodeEditor('data-inv-viewer', 'properties');
              if (dataViewer) {
                  dataViewer.setOption('readOnly', true);
                  dataViewer.getWrapperElement().style.minHeight = "auto";
                  dataViewer.getWrapperElement().style.height = "auto";
              }

              // 3. Fix the "Hidden Tab" CodeMirror Glitch
              // When the user clicks a tab, wait 50ms for it to become visible, then tell the editor to redraw
              document.querySelectorAll('.tablink').forEach(btn => {
                  btn.addEventListener('click', (e) => {
                      setTimeout(() => {
                          if (window.cmEditors['mgmt-inv-viewer']) window.cmEditors['mgmt-inv-viewer'].refresh();
                          if (window.cmEditors['data-inv-viewer']) window.cmEditors['data-inv-viewer'].refresh();
                      }, 50);
                  });
              });
          } else {
              console.error("Critical Error: labs.js factory failed to load!");
          }
      });
    </script>
